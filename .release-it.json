{
  "git": {
    "commitMessage": "release v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireUpstream": true,
    "requireCommits": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "assets": [
      "./out/vpn-deck-v*.zip"
    ],
    "draft": false,
    "preRelease": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": [
      "BRANCH=$(git branch --show-current) && if [[ \"$BRANCH\" != \"main\" ]]; then echo '⚠️  Вы не на ветке main. Текущая ветка: $BRANCH'; exit 1; fi"
    ],
    "before:release": [
      "bash infra/build-plugin.sh ${version}"
    ],
    "after:bump": "echo '✅ Версия обновлена до ${version}'"
  },
  "plugins": {}
}
